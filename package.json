{
  "name": "twitsh",
  "version": "1.1.1",
  "description": "X/Twitter data CLI with x402 micropayment handling",
  "type": "module",
  "bin": "dist/index.js",
  "files": [
    "dist",
    "skill.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node20 && cp skill.md ../app/public/skill.md",
    "prepare": "yarn build",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "mppx": "^0.4.7",
    "playwright": "^1.58.2",
    "viem": "^2.46.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/yargs": "^17",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/etherlect/twitsh.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
